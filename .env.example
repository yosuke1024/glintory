# Glintory Environment Variables Configuration Example

# Optional. Increases GitHub API limits for public-data collection.
GLINTORY_GITHUB_TOKEN=

# Signal Normalization & Constraints (Typically do not need to be changed by regular users)
# GLINTORY_SIGNAL_TITLE_MAX_CHARS=500
# GLINTORY_SIGNAL_EXCERPT_MAX_CHARS=5000
# GLINTORY_SIGNAL_URL_MAX_CHARS=4096
# GLINTORY_SIGNAL_METADATA_MAX_BYTES=65536
# GLINTORY_SIGNAL_HASH_VERSION=v1
# GLINTORY_SIGNAL_DEFAULT_SOURCE_QUALITY_SCORE=0.5

# Hacker News Collector Settings
# GLINTORY_HN_API_URL=https://hacker-news.firebaseio.com/v0
# GLINTORY_HN_WEB_ITEM_URL_TEMPLATE=https://news.ycombinator.com/item?id={item_id}
# GLINTORY_HN_TEXT_MAX_CHARS=5000

# Opportunity Scoring Settings
# GLINTORY_SCORING_VERSION=v1
# GLINTORY_SCORING_DEFAULT_TOP_LIMIT=3
# GLINTORY_SCORING_MAX_OPPORTUNITIES=1000
# GLINTORY_SCORING_SNAPSHOT_HISTORY_LIMIT=20

# Web & Review Workflow Settings
# GLINTORY_WEB_MAX_FORM_BYTES=65536
# GLINTORY_WEB_CSRF_COOKIE_NAME=glintory_csrf
# GLINTORY_WEB_CSRF_TOKEN_BYTES=32
# GLINTORY_REVIEW_NOTE_MAX_CHARS=5000
# GLINTORY_REVIEW_REASON_MAX_CHARS=1000
# GLINTORY_EVIDENCE_SEARCH_PER_PAGE=20

# Collection Operations Console Settings
# GLINTORY_COLLECTION_STALE_AFTER_MINUTES=60
# GLINTORY_COLLECTION_HISTORY_PER_PAGE=25
# GLINTORY_COLLECTION_ERROR_DISPLAY_MAX_CHARS=2000
# GLINTORY_COLLECTION_WEB_MAX_ITEMS=500



